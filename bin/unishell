#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
export UNISHELL_HOME="$(cd "$BIN_DIR/.." && pwd -P)"

# shellcheck source=/dev/null
. "$UNISHELL_HOME/core/loader.sh"

command_name="${1:-help}"
shift || true

case "$command_name" in
  init)
    unishell_init "$@"
    ;;
  doctor)
    unishell_doctor "$@"
    ;;
  off|exit|disable)
    warn "'unishell off' must run from a shell session where UniShell is sourced."
    info "Reload your shell config, then run: unishell off"
    info "For Zsh: source ~/.zshrc"
    exit 1
    ;;
  help|-h|--help)
    unishell_help
    ;;
  version|-v|--version)
    printf "UniShell v%s\n" "$UNISHELL_VERSION"
    ;;
  *)
    err "Unknown command: $command_name. Run 'unishell help'"
    exit 1
    ;;
esac
